{
  "name": "valhala-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Valhala Alcohol Delivery Platform",
  "main": "src/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "build": "echo 'No build step required'"
  },
  "dependencies": {
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.1.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "@sendgrid/mail": "^8.1.0",
    "google-maps-services-js": "^3.3.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "private": true,
  "overrides": {
    "uuid": "^11.0.3"
  }
}