# ============================================
# ROOT .gitignore - For Valhala Project
# ============================================

# Environment files (NEVER commit these!)
.env
.env.local
.env.*.local
.env.production
.env.development

# Dependencies
node_modules/
frontend/node_modules/
functions/node_modules/

# Build outputs
frontend/dist/
frontend/dist-ssr/
functions/lib/
functions/dist/

# Vercel
.vercel/

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
*.bridge-debug.log

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Environment specific
*.local

# Testing
coverage/
.nyc_output/

# Debug
*.pid
*.seed
*.pid.lock
*.trace
*.heapsnapshot

# Build cache
.eslintcache
*.tsbuildinfo